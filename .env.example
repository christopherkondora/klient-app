# Supabase Configuration
# Create a project at https://supabase.com and copy these values from Settings > API
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# LemonSqueezy Checkout URLs (get from LemonSqueezy dashboard after creating products)
LS_CHECKOUT_MONTHLY=
LS_CHECKOUT_YEARLY=
LS_CHECKOUT_LIFETIME=

# Deepgram (speech-to-text)
DEEPGRAM_API_KEY=
# OpenAI (AI features)
OPENAI_API_KEY=
